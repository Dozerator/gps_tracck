<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_card"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:letterSpacing="0.1"
        android:paddingBottom="16dp"
        android:text="@string/direction_dialog_title"
        android:textColor="@color/accent_orange"
        android:textSize="14sp" />

    <!-- Быстрые кнопки сторон света — крестообразный D-pad, снэп с анимацией 300мс.
         N/S закреплены по верху/низу и центрированы по горизонтали; W/E закреплены
         по краям и центрированы по вертикали между N и S — равные отступы, ромб. -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="176dp"
        android:layout_height="176dp"
        android:layout_gravity="center"
        android:layout_marginBottom="4dp">

        <LinearLayout
            android:id="@+id/btnN"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_quick_dir_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:duplicateParentState="true"
                android:rotation="0"
                android:src="@drawable/ic_arrow_up"
                android:tint="@color/quick_dir_content_color" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:duplicateParentState="true"
                android:text="N"
                android:textColor="@color/quick_dir_content_color"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnW"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_quick_dir_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:duplicateParentState="true"
                android:rotation="270"
                android:src="@drawable/ic_arrow_up"
                android:tint="@color/quick_dir_content_color" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:duplicateParentState="true"
                android:text="W"
                android:textColor="@color/quick_dir_content_color"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnE"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_quick_dir_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:duplicateParentState="true"
                android:rotation="90"
                android:src="@drawable/ic_arrow_up"
                android:tint="@color/quick_dir_content_color" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:duplicateParentState="true"
                android:text="E"
                android:textColor="@color/quick_dir_content_color"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnS"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_quick_dir_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:duplicateParentState="true"
                android:rotation="180"
                android:src="@drawable/ic_arrow_up"
                android:tint="@color/quick_dir_content_color" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:duplicateParentState="true"
                android:text="S"
                android:textColor="@color/quick_dir_content_color"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Компас: направление задаётся только вращением пальцем. Небольшой отрицательный
         отступ визуально связывает его с ромбом кнопок над ним. -->
    <com.example.operator.ui.CompassView
        android:id="@+id/compassView"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="center"
        android:layout_marginTop="-8dp" />

    <TextView
        android:id="@+id/tvAngle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingTop="8dp"
        android:text="0°"
        android:textColor="@color/accent_orange"
        android:textSize="32sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvDirectionLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingBottom="16dp"
        android:text="СЕВЕР"
        android:textColor="@color/dialog_text_secondary"
        android:textSize="14sp" />

    <!-- Точная настройка: тап ±1°, долгое нажатие ±5° -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingBottom="20dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMinus"
            android:layout_width="120dp"
            android:layout_height="44dp"
            android:text="◀  -1°"
            android:textColor="@color/dialog_text"
            app:backgroundTint="@color/direction_button_bg"
            app:cornerRadius="10dp" />

        <Space
            android:layout_width="16dp"
            android:layout_height="wrap_content" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPlus"
            android:layout_width="120dp"
            android:layout_height="44dp"
            android:text="+1°  ▶"
            android:textColor="@color/dialog_text"
            app:backgroundTint="@color/direction_button_bg"
            app:cornerRadius="10dp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/compassBackButton"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="@string/back_button"
            android:textColor="@color/dialog_text_secondary" />

        <Space
            android:layout_width="8dp"
            android:layout_height="wrap_content" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/compassCancelButton"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="@string/cancel_button"
            android:textColor="@color/dialog_text_secondary" />

        <Space
            android:layout_width="8dp"
            android:layout_height="wrap_content" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/compassConfirmButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="@string/compass_confirm_button"
            android:textColor="@color/dialog_text"
            android:textStyle="bold"
            app:backgroundTint="@color/accent_orange"
            app:cornerRadius="12dp" />

    </LinearLayout>

</LinearLayout>
