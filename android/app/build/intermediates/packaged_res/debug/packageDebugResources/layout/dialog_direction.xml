<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_card"
    android:padding="24dp">

    <TextView
        android:id="@+id/directionTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:text="@string/direction_dialog_title"
        android:textColor="@color/dialog_text"
        android:textSize="20sp"
        android:textStyle="bold" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="272dp"
        android:layout_height="272dp"
        android:layout_gravity="center_horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/northButton"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:gravity="center"
            android:maxLines="2"
            android:text="↑\nСЕВЕР"
            android:textColor="@color/dialog_text"
            android:textSize="12sp"
            app:backgroundTint="@color/direction_button_bg_selector"
            app:cornerRadius="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/westButton"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:gravity="center"
            android:maxLines="2"
            android:text="←\nЗАПАД"
            android:textColor="@color/dialog_text"
            android:textSize="12sp"
            app:backgroundTint="@color/direction_button_bg_selector"
            app:cornerRadius="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⊙"
            android:textColor="@color/dialog_text_secondary"
            android:textSize="20sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/eastButton"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:gravity="center"
            android:maxLines="2"
            android:text="→\nВОСТОК"
            android:textColor="@color/dialog_text"
            android:textSize="12sp"
            app:backgroundTint="@color/direction_button_bg_selector"
            app:cornerRadius="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/southButton"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:gravity="center"
            android:maxLines="2"
            android:text="↓\nЮГ"
            android:textColor="@color/dialog_text"
            android:textSize="12sp"
            app:backgroundTint="@color/direction_button_bg_selector"
            app:cornerRadius="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/directionBackButton"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/back_button"
            android:textColor="@color/dialog_text_secondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/directionCancelButton"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/cancel_button"
            android:textColor="@color/dialog_text_secondary" />

    </LinearLayout>

</LinearLayout>
