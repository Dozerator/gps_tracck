# Скопируйте этот файл в .env и заполните реальными значениями
DATABASE_URL=postgresql+psycopg2://operator_user:operator_pass@localhost:5432/operator_db
SECRET_KEY=change-this-to-a-long-random-secret-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Локальная разработка (без Nginx/TLS):
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
# Продакшн за Nginx с TLS — origin браузера будет https, замени IP на свой:
# ALLOWED_ORIGINS=https://192.168.1.100
